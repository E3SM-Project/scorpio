PIO_TF_AUTO_TEST_SUB_BEGIN init_finalize
  implicit none

  ! The default test driver should initialize and finalize PIO
  integer :: major, minor, patch
  character(LEN=PIO_MAX_NAME) :: vstr = ' '
  character(LEN=PIO_MAX_NAME) :: hstr = ' '
  integer :: ret

  ret = pio_get_version(major, minor, patch, vstr)
  PIO_TF_CHECK_ERR(ret, "Unable to retrieve version info")

  ret = pio_get_version_hash(hstr)
  PIO_TF_CHECK_ERR(ret, "Unable to retrieve version hash")

  PRINT *, "SCORPIO : ", "MAJOR VERSION : ", major,&
            ", MINOR VERSION : ", minor,&
            ", PATCH VERSION : ", patch,&
            ", VERSION STRING : '", trim(vstr), "'",&
            ", VERSION HASH : '", trim(hstr), "'"

PIO_TF_AUTO_TEST_SUB_END init_finalize


PIO_TF_AUTO_TEST_SUB_BEGIN set_debug_level
  implicit none

  INTEGER :: MIN_DBG_LVL = 0
  INTEGER :: MAX_DBG_LVL = 5
  INTEGER :: lvl, ret

  do lvl=MIN_DBG_LVL, MAX_DBG_LVL
    call pio_setdebuglevel(lvl)
    call pio_setdebuglevel(lvl, ret)
    PIO_TF_CHECK_ERR(ret, "Setting debug level failed")
  end do
  ! Reset to lowest level
  call pio_setdebuglevel(MIN_DBG_LVL)

PIO_TF_AUTO_TEST_SUB_END set_debug_level
